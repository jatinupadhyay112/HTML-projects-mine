<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Full Stack Form</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #060912;
      --card: rgba(255,255,255,0.04);
      --border: rgba(255,255,255,0.1);
      --accent: #4f8eff;
      --accent2: #a259ff;
      --text: #f0f0f5;
      --muted: rgba(240,240,245,0.4);
      --input-bg: rgba(255,255,255,0.06);
    }
    body {
      min-height: 100vh;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Sans', sans-serif;
      padding: 24px;
    }
    body::before, body::after {
      content: '';
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      z-index: 0;
      animation: float 8s ease-in-out infinite;
    }
    body::before {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(79,142,255,0.18), transparent 70%);
      top: -100px; left: -100px;
    }
    body::after {
      width: 350px; height: 350px;
      background: radial-gradient(circle, rgba(162,89,255,0.15), transparent 70%);
      bottom: -80px; right: -80px;
      animation-delay: -4s;
    }
    @keyframes float {
      0%, 100% { transform: translate(0,0); }
      50% { transform: translate(30px, 20px); }
    }
    .card {
      position: relative;
      z-index: 1;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 44px 40px;
      width: 100%;
      max-width: 460px;
      backdrop-filter: blur(24px);
      box-shadow: 0 30px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.08);
      animation: slideUp 0.6s cubic-bezier(0.22,1,0.36,1) both;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 8px;
      padding: 5px 14px;
      font-family: 'Syne', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      color: #fff;
      margin-bottom: 14px;
    }
    h1 {
      font-family: 'Syne', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 6px;
    }
    .subtitle {
      color: var(--muted);
      font-size: 13.5px;
      margin-bottom: 32px;
    }
    .field { margin-bottom: 20px; }
    label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.8px;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    input, select {
      width: 100%;
      padding: 13px 16px;
      background: var(--input-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      outline: none;
      transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
      appearance: none;
      -webkit-appearance: none;
    }
    input::placeholder { color: rgba(255,255,255,0.2); }
    input:focus, select:focus {
      border-color: var(--accent);
      background: rgba(79,142,255,0.07);
      box-shadow: 0 0 0 3px rgba(79,142,255,0.12);
    }
    select option { background: #0f1420; color: #fff; }
    .session-row {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 10px;
      align-items: center;
    }
    .arrow {
      color: var(--muted);
      font-size: 18px;
      text-align: center;
      padding-top: 2px;
    }
    .select-wrap { position: relative; }
    .select-wrap::after {
      content: '▾';
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      pointer-events: none;
      font-size: 12px;
    }
    .btn {
      width: 100%;
      margin-top: 28px;
      padding: 15px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border: none;
      border-radius: 12px;
      color: #fff;
      font-family: 'Syne', sans-serif;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 8px 24px rgba(79,142,255,0.3);
    }
    .btn:hover { opacity: 0.88; box-shadow: 0 12px 32px rgba(79,142,255,0.45); }
    .btn:active { transform: scale(0.98); }

    /* Success */
    .success { display: none; text-align: center; }
    .success.show { display: block; animation: slideUp 0.5s ease both; }
    .form-area.hide { display: none; }
    .tick {
      font-size: 56px;
      margin-bottom: 16px;
      animation: pop 0.4s cubic-bezier(0.36,0.07,0.19,0.97) both;
    }
    @keyframes pop {
      0% { transform: scale(0.3); opacity: 0; }
      60% { transform: scale(1.15); }
      100% { transform: scale(1); opacity: 1; }
    }
    .success h2 {
      font-family: 'Syne', sans-serif;
      font-size: 22px;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 6px;
    }
    .success p { color: var(--muted); font-size: 13.5px; margin-bottom: 24px; }
    .summary {
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 18px 22px;
      text-align: left;
      margin-bottom: 24px;
    }
    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 6px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .summary-row:last-child { border-bottom: none; }
    .summary-label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.6px; }
    .summary-val { color: var(--text); font-size: 14px; font-weight: 600; }
    .btn-outline {
      padding: 12px 28px;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-outline:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.25); }
  </style>
</head>
<body>

<div class="card">
  <!-- FORM -->
  <div class="form-area" id="formArea">
    <div class="badge">⚡ FULL STACK FORM</div>
    <h1>Student Registration</h1>
    <p class="subtitle">Please fill in your details below</p>

    <form id="myForm" novalidate>
      <div class="field">
        <label for="name">Full Name</label>
        <input type="text" id="name" placeholder="Enter your full name..." required />
      </div>

      <div class="field">
        <label for="course">Course</label>
        <div class="select-wrap">
          <select id="course" required>
            <option value="">Course</option>
            <option>B.Tech</option>
            <option>BCA</option>
            <option>MCA</option>
            <option>MBA</option>
            <option>B.Sc</option>
            <option>M.Sc</option>
            <option>B.Com</option>
            <option>BA</option>
            <option>MA</option>
            <option>BBA</option>
            <option>Ph.D</option>
            <option>Diploma</option>
          </select>
        </div>
      </div>

      <div class="field">
        <label>Session (Year to Year)</label>
        <div class="session-row">
          <div class="select-wrap">
            <select id="fromYear" required>
              <option value="">From</option>
            </select>
          </div>
          <div class="arrow">→</div>
          <div class="select-wrap">
            <select id="toYear" required>
              <option value="">To</option>
            </select>
          </div>
        </div>
      </div>

      <button type="submit" class="btn">Submit Form →</button>
    </form>
  </div>

  <!-- SUCCESS -->
  <div class="success" id="successArea">
    <div class="tick">✅</div>
    <h2>Form Submitted!</h2>
    <p>Your details have been saved successfully</p>
    <div class="summary" id="summary"></div>
    <button class="btn-outline" onclick="resetForm()">New Entry</button>
  </div>
</div>

<script>
  const currentYear = new Date().getFullYear();
  const fromSel = document.getElementById('fromYear');
  const toSel = document.getElementById('toYear');

  for (let y = currentYear - 4; y <= currentYear + 6; y++) {
    fromSel.innerHTML += `<option value="${y}">${y}</option>`;
    toSel.innerHTML += `<option value="${y}">${y}</option>`;
  }

  document.getElementById('myForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const name = document.getElementById('name').value.trim();
    const course = document.getElementById('course').value;
    const from = fromSel.value;
    const to = toSel.value;

    if (!name || !course || !from || !to) {
      alert('Please fill all fields!');
      return;
    }

    document.getElementById('summary').innerHTML = `
      <div class="summary-row"><span class="summary-label">Name</span><span class="summary-val">${name}</span></div>
      <div class="summary-row"><span class="summary-label">Course</span><span class="summary-val">${course}</span></div>
      <div class="summary-row"><span class="summary-label">Session</span><span class="summary-val">${from} – ${to}</span></div>
    `;

    document.getElementById('formArea').classList.add('hide');
    document.getElementById('successArea').classList.add('show');
  });

  function resetForm() {
    document.getElementById('myForm').reset();
    document.getElementById('formArea').classList.remove('hide');
    document.getElementById('successArea').classList.remove('show');
  }
</script>
</body>
</html>