<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registration Form</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f2f2f2;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
    }

    .form-container {
      background-color: white;
      padding: 30px 35px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      width: 100%;
      max-width: 420px;
    }

    h2 {
      text-align: center;
      margin-bottom: 24px;
      color: #333;
      font-size: 22px;
    }

    label {
      display: block;
      margin-bottom: 5px;
      font-size: 14px;
      color: #333;
    }

    input, select {
      width: 100%;
      padding: 9px 10px;
      margin-bottom: 6px;
      border: 1px solid #ccc;
      border-radius: 4px;
      font-size: 14px;
      box-sizing: border-box;
    }

    input:focus, select:focus {
      outline: none;
      border-color: #4a90e2;
    }

    .error {
      color: red;
      font-size: 12px;
      margin-bottom: 10px;
      display: none;
    }

    .password-wrap {
      position: relative;
    }

    .password-wrap input {
      padding-right: 70px;
    }

    .toggle-btn {
      position: absolute;
      right: 8px;
      top: 9px;
      background: none;
      border: none;
      color: #4a90e2;
      font-size: 13px;
      cursor: pointer;
      padding: 0;
    }

    .strength-bar {
      height: 5px;
      border-radius: 3px;
      background: #ddd;
      margin-bottom: 4px;
      display: none;
    }

    .strength-bar span {
      display: block;
      height: 100%;
      border-radius: 3px;
      width: 0%;
      transition: width 0.3s, background 0.3s;
    }

    .strength-text {
      font-size: 12px;
      margin-bottom: 10px;
      display: none;
    }

    .submit-btn {
      width: 100%;
      padding: 10px;
      background-color: #4a90e2;
      color: white;
      border: none;
      border-radius: 4px;
      font-size: 15px;
      cursor: pointer;
      margin-top: 6px;
    }

    .submit-btn:hover {
      background-color: #357abd;
    }

    .success-msg {
      text-align: center;
      color: green;
      font-size: 15px;
      margin-top: 14px;
      display: none;
    }
  </style>
</head>
<body>

<div class="form-container">
  <h2>Registration Form</h2>

  <label for="name">Full Name</label>
  <input type="text" id="name" placeholder="Enter your full name">
  <div class="error" id="nameErr">Please enter your full name.</div>

  <label for="email">Email Address</label>
  <input type="text" id="email" placeholder="Enter your email">
  <div class="error" id="emailErr">Please enter a valid email address.</div>

  <label for="phone">Phone Number</label>
  <input type="text" id="phone" placeholder="Enter 10-digit phone number" maxlength="10">
  <div class="error" id="phoneErr">Please enter a valid 10-digit phone number.</div>

  <label for="password">Password</label>
  <div class="password-wrap">
    <input type="password" id="password" placeholder="Create a password">
    <button class="toggle-btn" type="button" onclick="togglePassword()">Show</button>
  </div>
  <div class="strength-bar" id="strengthBar"><span id="strengthFill"></span></div>
  <div class="strength-text" id="strengthText"></div>
  <div class="error" id="passErr">Password must be at least 6 characters.</div>

  <button class="submit-btn" onclick="validateForm()">Register</button>
  <div class="success-msg" id="successMsg">Registration Successful!</div>
</div>

<script>
  function togglePassword() {
    var input = document.getElementById("password");
    var btn = document.querySelector(".toggle-btn");
    if (input.type === "password") {
      input.type = "text";
      btn.textContent = "Hide";
    } else {
      input.type = "password";
      btn.textContent = "Show";
    }
  }

  document.getElementById("password").addEventListener("input", function() {
    var val = this.value;
    var bar = document.getElementById("strengthBar");
    var fill = document.getElementById("strengthFill");
    var text = document.getElementById("strengthText");

    if (val.length === 0) {
      bar.style.display = "none";
      text.style.display = "none";
      return;
    }

    bar.style.display = "block";
    text.style.display = "block";

    var score = 0;
    if (val.length >= 6) score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^a-zA-Z0-9]/.test(val)) score++;

    if (score <= 2) {
      fill.style.width = "33%";
      fill.style.background = "red";
      text.textContent = "Weak";
      text.style.color = "red";
    } else if (score <= 3) {
      fill.style.width = "66%";
      fill.style.background = "orange";
      text.textContent = "Medium";
      text.style.color = "orange";
    } else {
      fill.style.width = "100%";
      fill.style.background = "green";
      text.textContent = "Strong";
      text.style.color = "green";
    }
  });

  function validateForm() {
    var valid = true;

    var name = document.getElementById("name").value.trim();
    var nameErr = document.getElementById("nameErr");
    if (name === "") {
      nameErr.style.display = "block";
      valid = false;
    } else {
      nameErr.style.display = "none";
    }

    var email = document.getElementById("email").value.trim();
    var emailErr = document.getElementById("emailErr");
    var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailPattern.test(email)) {
      emailErr.style.display = "block";
      valid = false;
    } else {
      emailErr.style.display = "none";
    }

    var phone = document.getElementById("phone").value.trim();
    var phoneErr = document.getElementById("phoneErr");
    if (!/^\d{10}$/.test(phone)) {
      phoneErr.style.display = "block";
      valid = false;
    } else {
      phoneErr.style.display = "none";
    }

    var pass = document.getElementById("password").value;
    var passErr = document.getElementById("passErr");
    if (pass.length < 6) {
      passErr.style.display = "block";
      valid = false;
    } else {
      passErr.style.display = "none";
    }

    if (valid) {
      document.getElementById("successMsg").style.display = "block";
    } else {
      document.getElementById("successMsg").style.display = "none";
    }
  }
</script>

</body>
</html>